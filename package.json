{
  "name": "blog",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "astro": "astro",
    "build": "astro build",
    "check": "npm-run-all2 --parallel --aggregate-output check:*",
    "check:astro": "astro check",
    "check:biome": "biome ci",
    "check:markuplint": "markuplint --config markuplint.config.ts **/*.astro",
    "check:stylelint": "stylelint --config stylelint.config.ts **/*.{css,astro}",
    "clean": "rimraf dist",
    "dev": "astro dev",
    "fmt": "npm-run-all2 --parallel fmt:*",
    "fmt:biome": "biome check --write --unsafe",
    "fmt:package": "sort-package-json",
    "fmt:style": "stylelint --config stylelint.config.ts --fix **/*.{css,astro}",
    "preview": "astro preview",
    "start": "astro dev",
    "test": "vitest run"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.8",
    "@astrojs/mdx": "5.0.3",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.2",
    "@biomejs/biome": "2.4.12",
    "@markuplint/astro-parser": "4.6.23",
    "@markuplint/ml-config": "4.8.15",
    "@microsoft/eslint-formatter-sarif": "3.1.0",
    "@types/sanitize-html": "2.16.1",
    "astro": "6.1.8",
    "browserslist": "4.28.2",
    "budoux": "0.8.1",
    "lightningcss": "1.32.0",
    "markuplint": "4.14.1",
    "npm-run-all2": "8.0.4",
    "rehype-autolink-headings": "7.1.0",
    "rehype-slug": "6.0.0",
    "rimraf": "6.1.3",
    "sanitize-html": "2.17.3",
    "sharp": "0.34.5",
    "sort-package-json": "3.6.1",
    "stylelint": "17.8.0",
    "stylelint-config-astro": "2.0.0",
    "stylelint-config-recess-order": "7.7.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-order": "8.1.1",
    "textlint": "15.5.4",
    "textlint-rule-no-dead-link": "6.2.1",
    "typescript": "6.0.3",
    "ufo": "1.6.3",
    "vitest": "4.1.4",
    "zod": "4.3.6"
  },
  "packageManager": "pnpm@10.33.0",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "10.33.0",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": "24.13.1",
      "onFail": "download"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild",
      "sharp"
    ]
  }
}
